# Copy to .env and fill in values — never commit .env
POSTGRES_DB=orbital
POSTGRES_USER=orbital
POSTGRES_PASSWORD=changeme

# Connection string used by the API (matches service name in compose)
DATABASE_URL=postgresql://orbital:changeme@orbital-db:5432/orbital

# API config
API_HOST=0.0.0.0
API_PORT=8200

# Frontend origin (for CORS)
FRONTEND_ORIGIN=http://localhost:5173
